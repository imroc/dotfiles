                                    {
                                        "set_variable": {
                                            "name": "esc_pressed_once",
                                            "value": 1
                                        }
                                    }
                                ],
                                "to_delayed_action": {
                                    "to_if_invoked": [
                                        {
                                            "set_variable": {
                                                "name": "esc_pressed_once",

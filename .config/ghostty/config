# 外观
# JetBrainsMono 作为默认字体，中文 fallback 到等距的更纱黑体，
# 以便在终端看含中文的 ASCII 图时能够对齐
font-family = JetBrainsMono Nerd Font
font-family = Sarasa Mono SC
font-size = 14
theme = TokyoNight Night
cursor-style = block

# split (pane)
keybind = super+enter=toggle_split_zoom
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right
split-inherit-working-directory = true

# Shift+Ejnter 发送换行符（解决 Zellij 下 Shift+Enter 无法换行的问题）
# keybind = shift+enter=text:\x1b[200~\n\x1b[201~
custom-shader = shaders/bloom025.glsl
custom-shader = shaders/cursor_blaze_no_trail.glsl
custom-shader = shaders/cursor_smear.glsl
window-padding-x = 4,2
window-padding-y = 6,0
confirm-close-surface = false
macos-icon = official
macos-titlebar-style = transparent
unfocused-split-opacity = 0.7

# quick terminal
keybind = global:ctrl+cmd+;=toggle_quick_terminal
quick-terminal-position = right
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.08

# tab
keybind = super+shift+r=prompt_tab_title
tab-inherit-working-directory = true

# resize
keybind = resize/k=resize_split:up,100
keybind = resize/j=resize_split:down,100
keybind = resize/h=resize_split:left,100
keybind = resize/l=resize_split:right,100
keybind = resize/escape=deactivate_key_table
keybind = resize/enter=deactivate_key_table
keybind = resize/catch_all=ignore
keybind = super+r=activate_key_table:resize

# scroll
keybind = super+u=scroll_page_up
keybind = chain=activate_key_table:scroll
keybind = scroll/k=scroll_page_lines:-3
keybind = scroll/j=scroll_page_lines:3
keybind = scroll/b=scroll_page_up
keybind = scroll/f=scroll_page_down
keybind = scroll/super+u=scroll_page_fractional:-0.5
keybind = scroll/u=scroll_page_fractional:-0.5
keybind = scroll/d=scroll_page_fractional:0.5
keybind = scroll/escape=deactivate_key_table
keybind = scroll/enter=deactivate_key_table
keybind = scroll/catch_all=ignore
keybind = super+s=activate_key_table:scroll

# 其它
macos-option-as-alt = true

# ----------------------
# 应用窗口自动放置规则
# ----------------------

# 新窗口出现时通知 sketchybar 刷新窗口状态
[[on-window-detected]]
    check-further-callbacks = true
    run = ['exec-and-forget sketchybar --trigger aerospace_windows_change FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused)']

# 默认 float 的窗口
[[on-window-detected]]
    if.app-id = 'com.apple.iCal'
    check-further-callbacks = true
    run = ['layout floating']
[[on-window-detected]]
    if.app-id = 'com.apple.finder'
    check-further-callbacks = true
    run = ['layout floating']
[[on-window-detected]]

# I: IntelliJ IDEA
[[on-window-detected]]
    if.app-id = 'com.jetbrains.intellij'
    run = ['move-node-to-workspace I']
[[on-window-detected]]
    if.app-id = 'com.jetbrains.cwm.guest'
    run = ['move-node-to-workspace I']
[[on-window-detected]]
    if.app-id = 'com.jetbrains.gateway'
    run = ['move-node-to-workspace I']
[[on-window-detected]]
    if.app-id = 'java.bin' # IntelliJ IDEA (via `idea .`)
    run = ['move-node-to-workspace I']

# J: 工作聊天
[[on-window-detected]]
    if.app-id = 'com.tencent.WeWorkMac'      # 企业微信主界面
    if.window-title-regex-substring = '^企业微信$'
    run = ['move-node-to-workspace J']

# T: 工具箱
[[on-window-detected]]
    if.app-id = 'net.kovidgoyal.kitty'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'net.shinystone.OKJSON'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'is.follow'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.microsoft.VSCode'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.tencent.codebuddycn'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.github.wez.wezterm'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.googlecode.iterm2'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'org.alacritty'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.tencent.weterm'
    if.window-title-regex-substring = '^WeTERM$'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'dev.zed.Zed'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.neovide.neovide'
    run = ['move-node-to-workspace T']
[[on-window-detected]]
    if.app-id = 'com.apple.Terminal'
    run = ['move-node-to-workspace T']

# Z: ZCode 代码编辑器
[[on-window-detected]]
    if.app-id = 'dev.zcode.app' # ZCode
    run = ['move-node-to-workspace Z']

# M: 会议
[[on-window-detected]]
    if.app-id = 'com.tencent.meeting'  # 腾讯会议
    if.window-title-regex-substring = '腾讯会议'
    run = ['move-node-to-workspace M']
[[on-window-detected]]
    if.app-id = 'com.tencent.wwmapp'   # 企微微信·会议
    run = ['move-node-to-workspace M']
[[on-window-detected]]
    if.app-id = 'com.electron.lark.iron'   # 飞书会议
    run = ['move-node-to-workspace M', 'layout floating']

# V：视频
[[on-window-detected]]
    if.app-id = 'com.tencent.tenvideo' # 腾讯视频
    run = ['move-node-to-workspace V']

# W: 网络浏览器
[[on-window-detected]]
    if.app-id = 'com.google.Chrome'
    run = ['move-node-to-workspace W']
[[on-window-detected]]
    if.app-id = 'org.mozilla.firefo4'
    run = ['move-node-to-workspace W']
[[on-window-detected]]
    if.app-id = 'com.apple.Safari'
    run = ['move-node-to-workspace W']
[[on-window-detected]]
    if.app-id = 'com.microsoft.edgemac'
    run = ['move-node-to-workspace W']

#!/usr/bin/env bash

source "$CONFIG_DIR/environment"
source "$THEME_DIR/tokyonight"

# в”Җв”Җ Bluetooth devices в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
#   name            MAC                 icon
devices=(
  "bt_freearc      64-b0-e8-fb-56-68   уұЎҸ"   # HUAWEI FreeArc иҖіжҢӮиҖіжңә
  "bt_headphone    88-c9-e8-24-e6-7e   у°ӢӢ"   # Sony WH-1000XM4 еӨҙжҲҙиҖіжңә
  "bt_keyboard     f5-aa-e4-10-93-dd   у°ҢҢ"   # HHKB й”®зӣҳ
  "bt_mouse        00-81-2a-94-bd-6c   у°ҚҪ"   # Magic йј ж Ү
)

for entry in "${devices[@]}"; do
  read -r name addr icon <<<"$entry"

  sketchybar --add event "${name}_status_change"

  sketchybar --add item "$name" right \
    --subscribe "$name" "${name}_status_change" \
    --set "$name" \
    drawing=off \
    background.drawing=off \
    icon.drawing=on \
    icon.font="$ICON_BASE_FONT:Bold:15.0" \
    icon="$icon" \
    icon.color="$green" \
    icon.padding_left=0 \
    icon.padding_right=6 \
    label.drawing=off \
    update_freq=60 \
    script="BT_DEVICE=$addr $PLUGIN_DIR/bt_device"
done

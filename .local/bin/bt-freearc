#!/bin/bash
# Toggle connect/disconnect for HUAWEI FreeArc bluetooth earbuds
#
# NOTE: Use osascript to invoke blueutil so that the Bluetooth TCC check
# falls on AeroSpace.app (which must be listed in Privacy > Bluetooth).
#
# 连接成功/断开的系统通知由 sketchybar-notifier 守护进程统一处理（IOBluetooth 事件驱动），
# 本脚本只负责：1) 执行蓝牙操作  2) "正在连接"提示  3) 连接失败提示（超时无 IOBluetooth 事件）

osascript -e '
set deviceAddr to "64-b0-e8-fb-56-68"
set deviceName to "HUAWEI FreeArc"
set blu to "/opt/homebrew/bin/blueutil"

try
    set connected to (do shell script blu & " --is-connected " & deviceAddr)
on error errMsg
    display notification errMsg with title deviceName sound name "Basso"
    return
end try

if connected = "1" then
    do shell script blu & " --disconnect " & deviceAddr
else
    display notification "正在连接..." with title deviceName sound name "Tink"
    try
        do shell script blu & " --connect " & deviceAddr & " --wait-connect " & deviceAddr & " 5"
    on error
        display notification "连接失败，请确认耳机已开启" with title deviceName sound name "Basso"
    end try
end if
'
